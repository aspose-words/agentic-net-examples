  "rules_summary": {
    "strict_api_bans": [
      "Do not use System.Drawing in this category.",
      "Do not assume input files already exist; bootstrap them locally when needed.",
      "Do not start a real web server or HTTP listener for response-stream tasks.",
      "Do not use an incorrect SaveFormat for the requested output extension."
    ],
    "canonical_patterns": [
      "Create local DOC/DOCX/HTML/TXT/XML inputs inside the example when the task implies an existing source.",
      "Use the correct Document loading workflow and the correct SaveFormat or SaveOptions for the target output.",
      "Simulate network or browser responses with MemoryStream instead of hosting a real server.",
      "Validate output files exist or output streams contain data before finishing."
    ],
    "nullable_warning_prevention": [
      "Initialize all non-nullable reference type properties to avoid CS8618 warnings.",
      "Avoid CS8600, CS8602, and CS8604 by guarding maybe-null values before dereference or assignment.",
      "Declare nullable locals when a value may legitimately be null and null-check before use."
    ]
  },
  "common_failure_patterns": [
    {
      "pattern": "System.Drawing or Font ambiguity",
      "symptom": "Compile errors caused by System.Drawing usage or ambiguous Font references between Aspose.Drawing.Font and Aspose.Words.Font.",
      "fix": "Use Aspose.Drawing only, and declare drawing fonts explicitly as Aspose.Drawing.Font."
    },
    {
      "pattern": "Missing input bootstrap",
      "symptom": "Conversion task assumes a DOC, DOCX, HTML, TXT, XML, folder, or other source already exists.",
      "fix": "Create the local source file, source document, or input folder inside the example before loading it."
    },
    {
      "pattern": "Response-stream task hangs",
      "symptom": "Example starts a server or waits for a request instead of finishing.",
      "fix": "Simulate the response with a MemoryStream, write conversion output to it, validate length, and exit."
    },
    {
      "pattern": "Incorrect SaveFormat or extension pairing",
      "symptom": "Output format does not match the requested target type or file extension.",
      "fix": "Use the correct SaveFormat or specialized SaveOptions for the requested output."
    },
    {
      "pattern": "Stream position or disposal issue",
      "symptom": "Reloading or reading a stream fails because Position was not reset or the stream was disposed too early.",
      "fix": "Reset MemoryStream.Position before reading and keep the stream alive until validation is complete."
    }
  ],
